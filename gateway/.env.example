# Gateway Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="AI Assistant Gateway"
DEBUG=true

# Supabase Configuration
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=ysb_publishable_ACJWlzQHlZjBrEguHvfOxg_3
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# Database URL
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Inference Endpoints
# Set these to your GPU pod URLs when ready
# Examples:
#   vLLM:   http://<gpu-pod-ip>:8000
#   Ollama: http://<gpu-pod-ip>:11434
#   TGI:    http://<gpu-pod-ip>:8080
INFERENCE_INSTANT_URL=
INFERENCE_THINKING_URL=

# Inference Model Settings
INFERENCE_MODEL_NAME=default          # Model name sent to server (e.g., mistralai/Mistral-7B-Instruct-v0.3)
INFERENCE_MAX_TOKENS=2048             # Max tokens in response
INFERENCE_TEMPERATURE=0.7             # Sampling temperature (0.0 - 1.0)
INFERENCE_TIMEOUT=120.0               # Request timeout in seconds
INFERENCE_STREAM=true                 # Enable streaming responses
